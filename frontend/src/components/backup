/* ─── Keyframe injection (one-shot) ─── */
function injectKeyframes() {
  if (document.getElementById("rezi-kf")) return;
  const style = document.createElement("style");
  style.id = "rezi-kf";
  style.textContent = `
    @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap');

    @keyframes rezi-fadeUp {
      from { opacity:0; transform:translateY(18px); }
      to   { opacity:1; transform:translateY(0); }
    }
    @keyframes rezi-fadeIn {
      from { opacity:0; } to { opacity:1; }
    }
    @keyframes rezi-float {
      0%,100% { transform:translateY(0px); }
      50%      { transform:translateY(-6px); }
    }
    @keyframes rezi-pulse-ring {
      0%   { transform:scale(1);   opacity:.6; }
      100% { transform:scale(1.7); opacity:0;  }
    }
    @keyframes rezi-cursor {
      0%,100% { opacity:1; } 50% { opacity:0; }
    }
    @keyframes rezi-bar-fill {
      from { width:0%; } to { width:82%; }
    }
    @keyframes rezi-shimmer {
      0%   { background-position: -400px 0; }
      100% { background-position:  400px 0; }
    }
    @keyframes rezi-orbit {
      from { transform: rotate(0deg)   translateX(var(--r)) rotate(0deg);   }
      to   { transform: rotate(360deg) translateX(var(--r)) rotate(-360deg); }
    }
    @keyframes rezi-type {
      from { width:0; } to { width:100%; }
    }
    @keyframes rezi-particle-drift {
      0%   { transform:translateY(0px)  scale(1);   opacity:.7; }
      50%  { transform:translateY(-14px) scale(1.2); opacity:1;  }
      100% { transform:translateY(0px)  scale(1);   opacity:.7; }
    }
    @keyframes rezi-line-appear {
      from { transform:scaleX(0); transform-origin:left; }
      to   { transform:scaleX(1); transform-origin:left; }
    }
    @keyframes rezi-badge-pop {
      0%   { transform:scale(0.8) translateY(6px); opacity:0; }
      70%  { transform:scale(1.04); opacity:1; }
      100% { transform:scale(1); opacity:1; }
    }
    @keyframes rezi-magnetic-glow {
      0%,100% { box-shadow: 0 0 0 0px rgba(42,122,111,0.35); }
      50%     { box-shadow: 0 0 0 6px rgba(42,122,111,0.12); }
    }
    @keyframes rezi-section-line {
      from { opacity:0; transform:scaleX(0); transform-origin:left; }
      to   { opacity:1; transform:scaleX(1); transform-origin:left; }
    }
  `;
  document.head.appendChild(style);
}

/* ─── Three.js canvas (floating geometry) ─── */
function ThreeCanvas({ visible }) {
  const mountRef = useRef(null);
  const stateRef = useRef({});

  useEffect(() => {
    if (!visible) return;
    let THREE;
    let rafId;

    async function init() {
      try {
        THREE = await import("three");
      } catch { return; }

      const mount = mountRef.current;
      if (!mount) return;

      const W = mount.offsetWidth, H = mount.offsetHeight;
      const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setSize(W, H);
      renderer.setClearColor(0x000000, 0);
      mount.appendChild(renderer.domElement);

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(40, W / H, 0.1, 100);
      camera.position.set(0, 0, 6);

      /* Soft ambient + directional light */
      scene.add(new THREE.AmbientLight(0xfaf8f3, 0.9));
      const dir = new THREE.DirectionalLight(0xf5c87a, 0.6);
      dir.position.set(3, 4, 3);
      scene.add(dir);
      const dir2 = new THREE.DirectionalLight(0x9fd4cf, 0.4);
      dir2.position.set(-3, -2, 2);
      scene.add(dir2);

      /* Resume card plane */
      const cardGeo = new THREE.PlaneGeometry(2.2, 2.8, 1, 1);
      const cardMat = new THREE.MeshStandardMaterial({
        color: 0xfaf8f3,
        roughness: 0.3,
        metalness: 0.04,
        transparent: true,
        opacity: 0.92,
      });
      const card = new THREE.Mesh(cardGeo, cardMat);
      card.position.set(0, 0.1, 0);
      scene.add(card);

      /* Card edge bevel (thin white plane overlay) */
      const edgeGeo = new THREE.PlaneGeometry(2.2, 2.8);
      const edgeMat = new THREE.MeshBasicMaterial({
        color: 0xffffff,
        transparent: true,
        opacity: 0.06,
        side: THREE.BackSide,
      });
      const edge = new THREE.Mesh(edgeGeo, edgeMat);
      edge.position.copy(card.position);
      scene.add(edge);

      /* Floating skill tag planes */
      const tagColors = [0x2a7a6f, 0xc47b2b, 0x4aada0, 0x1c5c56];
      const tags = [];
      [
        [-1.6,  0.9, 0.6],
        [ 1.7,  0.5, 0.4],
        [-1.5, -0.7, 0.5],
        [ 1.6, -0.9, 0.45],
      ].forEach(([x, y, z], i) => {
        const g = new THREE.PlaneGeometry(0.7, 0.22);
        const m = new THREE.MeshStandardMaterial({
          color: tagColors[i],
          roughness: 0.5,
          transparent: true,
          opacity: 0.82,
        });
        const mesh = new THREE.Mesh(g, m);
        mesh.position.set(x, y, z);
        scene.add(mesh);
        tags.push({ mesh, baseY: y, phase: i * 0.8 });
      });

      /* Tiny particle dots */
      const ptGeo = new THREE.BufferGeometry();
      const count = 40;
      const pos = new Float32Array(count * 3);
      for (let i = 0; i < count; i++) {
        pos[i*3]   = (Math.random() - 0.5) * 7;
        pos[i*3+1] = (Math.random() - 0.5) * 5;
        pos[i*3+2] = (Math.random() - 0.5) * 2 - 0.5;
      }
      ptGeo.setAttribute("position", new THREE.BufferAttribute(pos, 3));
      const ptMat = new THREE.PointsMaterial({ color: 0x2a7a6f, size: 0.03, transparent: true, opacity: 0.5 });
      scene.add(new THREE.Points(ptGeo, ptMat));

      /* Mouse parallax */
      let mx = 0, my = 0;
      const onMouse = (e) => {
        const rect = mount.getBoundingClientRect();
        mx = ((e.clientX - rect.left) / W - 0.5) * 2;
        my = -((e.clientY - rect.top) / H - 0.5) * 2;
      };
      window.addEventListener("mousemove", onMouse);
      stateRef.current.cleanup = () => {
        window.removeEventListener("mousemove", onMouse);
        cancelAnimationFrame(rafId);
        renderer.dispose();
        if (mount.contains(renderer.domElement)) mount.removeChild(renderer.domElement);
      };

      /* Animate */
      let t = 0;
      const animate = () => {
        rafId = requestAnimationFrame(animate);
        t += 0.008;

        /* Gentle card tilt following mouse */
        card.rotation.y = THREE.MathUtils.lerp(card.rotation.y, mx * 0.18, 0.05);
        card.rotation.x = THREE.MathUtils.lerp(card.rotation.x, my * 0.12, 0.05);

        /* Tags float */
        tags.forEach(({ mesh, baseY, phase }) => {
          mesh.position.y = baseY + Math.sin(t + phase) * 0.08;
          mesh.rotation.z = Math.sin(t * 0.5 + phase) * 0.04;
        });

        renderer.render(scene, camera);
      };
      animate();
    }

    init();
    return () => stateRef.current.cleanup?.();
  }, [visible]);

  return (
    <div
      ref={mountRef}
      style={{
        position: "absolute", inset: 0,
        pointerEvents: "none",
        opacity: visible ? 1 : 0,
        transition: "opacity 0.8s ease",
      }}
    />
  );
}

