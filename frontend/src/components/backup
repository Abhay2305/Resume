        gap: 80,
      }}>

        {/* ══ LEFT: Copy ══ */}
        <div style={{ paddingTop: 80, paddingBottom: 80 }}>

          {/* Mode badge */}
          <div style={{
            ...delayStyle("0.1s"),
            display: "inline-flex", alignItems: "center", gap: 8,
            background: T.tealFaint,
            border: `1px solid rgba(42,122,111,0.18)`,
            borderRadius: 20, padding: "5px 14px",
            marginBottom: 28,
          }}>
            <div style={{
              width: 6, height: 6, borderRadius: "50%",
              background: T.teal,
              position: "relative",
            }}>
              <div style={{
                position: "absolute", inset: -2, borderRadius: "50%",
                border: `1.5px solid ${T.teal}`,
                animation: "rezi-pulse-ring 2s ease-out infinite",
              }} />
            </div>
            <span style={{
              fontSize: 12, color: T.teal, fontWeight: 500,
              letterSpacing: "0.03em",
            }}>
              AI-Powered · ATS-Optimized
            </span>
          </div>

          {/* Headline */}
          <h1 style={{
            ...delayStyle("0.22s"),
            fontFamily: "'DM Serif Display', serif",
            fontSize: "clamp(38px, 4.5vw, 58px)",
            fontWeight: 400,
            lineHeight: 1.12,
            color: T.charcoal,
            letterSpacing: "-0.025em",
            margin: "0 0 22px",
          }}>
            Build resumes that<br />
            <em style={{ color: T.teal, fontStyle: "italic" }}>actually get</em><br />
            noticed.
          </h1>

          {/* Sub */}
          <p style={{
            ...delayStyle("0.36s"),
            fontSize: 16, color: T.stone,
            lineHeight: 1.65, maxWidth: 420,
            margin: "0 0 32px",
            fontWeight: 300,
          }}>
            Describe yourself in plain English and generate a professional, ATS-friendly resume in seconds. Edit everything manually whenever you want.
          </p>

          {/* Mode chips */}
          <div style={{
            ...delayStyle("0.48s"),
            display: "flex", gap: 10, flexWrap: "wrap", marginBottom: 36,
          }}>
            {[
              { dot: T.teal,  label: "AI Prompt Mode — instant generation" },
              { dot: T.amber, label: "Manual Mode — full control" },
            ].map(({ dot, label }) => (
              <div key={label} style={{
                display: "inline-flex", alignItems: "center", gap: 7,
                background: "rgba(28,26,23,0.04)",
                border: `1px solid ${T.border}`,
                borderRadius: 8, padding: "6px 12px",
                fontSize: 12, color: T.stone,
              }}>
                <div style={{ width: 5, height: 5, borderRadius: "50%", background: dot, flexShrink: 0 }} />
                {label}
              </div>
            ))}
          </div>

          {/* CTAs */}
          <div style={{
            ...delayStyle("0.6s"),
            display: "flex", gap: 12, alignItems: "center", flexWrap: "wrap",
          }}>
            <MagneticButton primary>
              Build my resume
              <span style={{ fontSize: "1.1em", marginLeft: 2 }}>→</span>
            </MagneticButton>
            <MagneticButton>
              Explore templates
            </MagneticButton>
          </div>

          {/* Trust line */}
          <div style={{
            ...delayStyle("0.74s"),
            marginTop: 22, display: "flex", gap: 18,
            fontSize: 12, color: T.muted,
          }}>
            <span>✓ Export in seconds</span>
            <span>✓ No account needed to start</span>
          </div>
        </div>

        {/* ══ RIGHT: Visual ══ */}
        <div style={{
          position: "relative",
          display: "flex",
          justifyContent: "center",
          alignItems: "center",
          paddingTop: 80, paddingBottom: 80,
          animation: mounted ? "rezi-fadeIn 0.8s ease 0.5s both" : "none",
          opacity: 0,
        }}>
          {/* Three.js canvas behind cards */}
          <div style={{ position: "absolute", inset: 0, zIndex: 0 }}>
            <ThreeCanvas visible={threeReady} />
          </div>

          {/* Floating glow disc */}
          <div style={{
            position: "absolute",
            width: 300, height: 300,
            borderRadius: "50%",
            background: `radial-gradient(circle, rgba(42,122,111,0.10) 0%, transparent 70%)`,
            top: "50%", left: "50%",
            transform: "translate(-50%,-50%)",
            pointerEvents: "none",
            zIndex: 1,
            animation: "rezi-float 6s ease-in-out infinite",
          }} />

          {/* Resume card (main) */}
          <div style={{ position: "relative", zIndex: 2, animation: "rezi-float 7s ease-in-out infinite" }}>
            <ResumeCard visible={mounted} />

            {/* Overlaid badges */}
            <ATSBadge visible={mounted} />
            <AIPromptCard visible={mounted} />
            <ExportChip visible={mounted} />

            {/* Manual editing badge */}
            <div style={{
              position: "absolute",
              top: -16, left: -20,
              background: T.glass,
              backdropFilter: "blur(8px)",
              WebkitBackdropFilter: "blur(8px)",
              border: `1px solid ${T.borderMed}`,
              borderRadius: 10,
              padding: "8px 12px",
              boxShadow: "0 4px 16px rgba(28,26,23,0.08)",
              display: "flex", alignItems: "center", gap: 7,
              animation: mounted ? "rezi-badge-pop 0.5s cubic-bezier(.34,1.56,.64,1) 1.8s both" : "none",
              opacity: 0,
            }}>
              <span style={{ fontSize: 14 }}>✏️</span>
              <div>
                <div style={{
                  fontFamily: "'DM Sans', sans-serif",
                  fontSize: 10, fontWeight: 500, color: T.charcoal,
                  letterSpacing: "-0.01em",
                }}>Manual editing</div>
                <div style={{
                  fontFamily: "'DM Sans', sans-serif",
                  fontSize: 9, color: T.muted,
                }}>available anytime</div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>
  );
}