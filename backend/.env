# Database configuration - defaults to SQLite for local development
DATABASE_URL=sqlite:///./resume_builder.db

# JWT Configuration
JWT_SECRET_KEY=super_secret_resume_key_jwt_token_123456789

# AI Layer Configuration (Gemini API Key)
# Replace with your actual Gemini API Key (obtain from Google AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Server Port (default 8000)
PORT=8000
